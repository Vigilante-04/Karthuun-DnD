<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Karthuun NPC Index</title>

<style>
body{
    background:#111;
    color:#eee;
    font-family:serif;
    padding:40px;
}

h1{
    text-align:center;
}

#npcContainer{
    display:grid;
    grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
    gap:20px;
}

.card{
    background:#1d1d1d;
    border-radius:10px;
    padding:15px;
}

.card img{
    width:100%;
    border-radius:6px;
}

.name{
    font-size:20px;
    font-weight:bold;
}

.meta{
    font-size:14px;
    opacity:0.8;
}
</style>

</head>

<body>

<h1>Karthuun NPC Index</h1>

<div id="npcContainer"></div>

<script>

const NPC_SHEET_CSV_URL =
"https://docs.google.com/spreadsheets/d/e/2PACX-1vSMWKaNuiGKg_JmWT6G-eIm_2b9djoLisLoLkoRXvVDjo9xvUBK3HJrhnilNSA4kNMO9PxVYqlZz69U/pub?gid=0&single=true&output=csv";

async function loadNPCs(){

    const response = await fetch(NPC_SHEET_CSV_URL);
    const data = await response.text();

    const rows = data.split("\n").slice(1);

    const container = document.getElementById("npcContainer");

    rows.forEach(row=>{

        const cols = row.split(",");

        const name = cols[3] || "";
        const surname = cols[4] || "";
        const race = cols[6] || "";
        const role = cols[9] || "";
        const location = cols[10] || "";
        const image = cols[13] || "";

        const card = document.createElement("div");
        card.className = "card";

        card.innerHTML = `
        ${image ? `<img src="${image.replace("/view","/preview")}">` : ""}
        <div class="name">${name} ${surname}</div>
        <div class="meta">${race}</div>
        <div class="meta">${role}</div>
        <div class="meta">Met: ${location}</div>
        `;

        container.appendChild(card);

    });

}

loadNPCs();

</script>

</body>
</html>
