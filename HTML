<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Karthuun World</title>
<style>
body {
    font-family: "Georgia", serif;
    background: #111;
    color: #eee;
    margin: 0;
}

header {
    background: #222;
    padding: 15px;
    display: flex;
    justify-content: center;
}

header button {
    background: #333;
    color: #eee;
    border: none;
    padding: 10px 20px;
    margin: 0 5px;
    cursor: pointer;
    border-radius: 5px;
}

header button.active {
    background: #555;
}

section {
    display: none;
    padding: 20px;
}

section.active {
    display: block;
}

/* NPC Cards */
#npcContainer {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 25px;
}

.card {
    position: relative;
    background: #1d1d1d;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 15px rgba(0,0,0,0.7);
}

.card .background {
    width: 100%;
    height: 180px;
    object-fit: cover;
    opacity: 0.6;
}

.card img.npcImage {
    position: absolute;
    top: 20px;
    left: 50%;
    transform: translateX(-50%);
    width: 120px;
    height: 120px;
    border-radius: 50%;
    border: 3px solid #fff;
    object-fit: cover;
    z-index: 2;
}

.card .info {
    padding: 150px 15px 15px 15px;
}

.card .info h2 {
    margin: 0 0 5px 0;
}

.card .info p {
    margin: 2px 0;
    font-size: 14px;
    opacity: 0.9;
}
</style>
</head>
<body>

<header>
    <button class="tabButton active" data-target="npcTab">NPCs</button>
    <button class="tabButton" data-target="locationTab">Locations</button>
    <button class="tabButton" data-target="mapTab">Map (Coming Soon)</button>
</header>

<section id="npcTab" class="active">
    <h1>NPC Tracker</h1>
    <div id="npcContainer"></div>
</section>

<section id="locationTab">
    <h1>Locations</h1>
    <div id="locationContainer"></div>
</section>

<section id="mapTab">
    <h1>Map</h1>
    <p>Map functionality coming soon...</p>
</section>

<script>
// ---------------- Tabs ----------------
const buttons = document.querySelectorAll(".tabButton");
buttons.forEach(btn=>{
    btn.addEventListener("click",()=>{
        buttons.forEach(b=>b.classList.remove("active"));
        document.querySelectorAll("section").forEach(s=>s.classList.remove("active"));
        btn.classList.add("active");
        document.getElementById(btn.dataset.target).classList.add("active");
    });
});

// ---------------- CSV URLs ----------------
const NPC_SHEET_CSV_URL =
"https://docs.google.com/spreadsheets/d/e/2PACX-1vSMWKaNuiGKg_JmWT6G-eIm_2b9djoLisLoLkoRXvVDjo9xvUBK3HJrhnilNSA4kNMO9PxVYqlZz69U/pub?gid=0&single=true&output=csv";

const LOCATION_SHEET_CSV_URL =
"https://docs.google.com/spreadsheets/d/e/2PACX-1vSMWKaNuiGKg_JmWT6G-eIm_2b9djoLisLoLkoRXvVDjo9xvUBK3HJrhnilNSA4kNMO9PxVYqlZz69U/pub?gid=30016903&single=true&output=csv";

// ---------------- Helpers ----------------
function driveLinkToDirect(url) {
    if(!url) return "";
    let match = url.match(/\/d\/([a-zA-Z0-9_-]+)\//);
    if(match){
        return `https://drive.google.com/uc?export=view&id=${match[1]}`;
    }
    return url;
}

async function loadCSV(url){
    const res = await fetch(url);
    if(!res.ok) throw new Error("Failed to load CSV: "+res.status);
    const text = await res.text();
    const lines = text.split("\n").filter(l=>l.trim()!=="");
    const headers = lines[0].split(",");
    return lines.slice(1).map(line=>{
        const cols = line.split(",");
        let obj={};
        headers.forEach((h,i)=> obj[h.trim()]=cols[i]||"");
        return obj;
    });
}

// ---------------- Build NPC Cards ----------------
async function buildNPCs(){
    const npcs = await loadCSV(NPC_SHEET_CSV_URL);
    const locations = await loadCSV(LOCATION_SHEET_CSV_URL);
    const container = document.getElementById("npcContainer");

    npcs.forEach(npc=>{
        const location = locations.find(l => l["Location Name"].trim() === npc["Last Known Location"].trim());
        const bgImg = location ? driveLinkToDirect(location["Location Image"]) : "";
        const npcImg = driveLinkToDirect(npc["Picture"]);

        const card = document.createElement("div");
        card.className="card";
        card.innerHTML=`
            ${bgImg ? `<img class="background" src="${bgImg}">` : ""}
            ${npcImg ? `<img class="npcImage" src="${npcImg}">` : ""}
            <div class="info">
                <h2>${npc["Title/Alias"]} ${npc["Name"]} ${npc["Surname"]}</h2>
                <p>Status: ${npc["Status"]}</p>
                <p>Race: ${npc["Race"]}</p>
                <p>Gender: ${npc["Gender"]}</p>
                <p>Faction: ${npc["Faction/Affiliation"]}</p>
                <p>Role: ${npc["Occupation/Role"]}</p>
                <p>Met: ${npc["Location Met"]}</p>
                <p>Last Known Location: ${npc["Last Known Location"]}</p>
                <p>Relationship & Knowledge: ${npc["Relationship & Knowledge of"]}</p>
            </div>
        `;
        container.appendChild(card);
    });
}

// ---------------- Build Locations (simple list) ----------------
async function buildLocations(){
    const locations = await loadCSV(LOCATION_SHEET_CSV_URL);
    const container = document.getElementById("locationContainer");
    locations.forEach(loc=>{
        const div = document.createElement("div");
        div.style.marginBottom="20px";
        div.innerHTML=`
            <h3>${loc["Location Name"]}</h3>
            ${loc["Location Image"] ? `<img src="${driveLinkToDirect(loc["Location Image"])}" style="width:300px;border:2px solid #ccc;">` : ""}
        `;
        container.appendChild(div);
    });
}

// ---------------- Initialize ----------------
buildNPCs().catch(e=>console.error(e));
buildLocations().catch(e=>console.error(e));
</script>

</body>
</html>
